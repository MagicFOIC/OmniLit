OMNILIT_DOMAIN=omnilit.example.com
OMNILIT_ACME_EMAIL=admin@example.com
OMNILIT_APP_VERSION=0.1.0

OMNILIT_POSTGRES_DATABASE=omnilit
OMNILIT_POSTGRES_USER=omnilit
OMNILIT_POSTGRES_PASSWORD_FILE=./secrets/postgres-password.txt
OMNILIT_CLOUD_DATA_KEY_FILE=./secrets/cloud-data-key.txt
OMNILIT_CLOUD_METRICS_TOKEN_FILE=./secrets/cloud-metrics-token.txt

OMNILIT_TURNSTILE_SITE_KEY=replace-with-site-key
OMNILIT_TURNSTILE_SECRET_FILE=./secrets/turnstile-secret.txt
OMNILIT_SMTP_HOST=smtp.example.com
OMNILIT_SMTP_PORT=587
OMNILIT_SMTP_USER=omnilit@example.com
OMNILIT_SMTP_PASSWORD_FILE=./secrets/smtp-password.txt
OMNILIT_SMTP_FROM=OmniLit <omnilit@example.com>

OMNILIT_S3_REPOSITORY=s3:https://s3.example.com/omnilit-backups
OMNILIT_S3_ACCESS_KEY_FILE=./secrets/s3-access-key.txt
OMNILIT_S3_SECRET_KEY_FILE=./secrets/s3-secret-key.txt
OMNILIT_RESTIC_PASSWORD_FILE=./secrets/restic-password.txt
OMNILIT_BACKUP_INTERVAL_SECONDS=86400
OMNILIT_BACKUP_KEEP_DAILY=14

OMNILIT_DEFAULT_QUOTA_BYTES=5368709120
OMNILIT_PUBLIC_MAX_FILE_BYTES=209715200
OMNILIT_PROMETHEUS_PORT=9090
